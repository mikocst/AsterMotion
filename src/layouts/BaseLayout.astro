---
import '../styles/global.css';
import NavBar from '../components/NavBar';
import { AsterProvider } from '../context/AsterContext';

interface Props {
	title?: string;
}

const { title = 'AsterMotion' } = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
	</head>
	<body>
		<main>
			<AsterProvider client:load>
				<div class="relative">
					<NavBar />
					<slot />
				</div>
			</AsterProvider>
		</main>
	</body>
</html>
